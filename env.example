# Contact form — email delivery (Resend)
# Production (Vercel): Project Settings → Environment Variables → add all vars below for Production + Preview.
CONTACT_EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_key_from_resend_dashboard
CONTACT_FROM_EMAIL=Phaarvai <partnerships@phaarvai.com>
CONTACT_TO_EMAIL=partnerships@phaarvai.com

# Optional: Postmark instead of Resend
POSTMARK_SERVER_TOKEN=

# Optional: persist submissions as JSONL on the server filesystem
CONTACT_PERSIST=true
CONTACT_DATA_DIR=.data

# Optional: Slack or monitoring webhook on submission
CONTACT_WEBHOOK_URL=

# Local: copy to .env.local, fill RESEND_API_KEY, then npm run dev && npm run test:contact
